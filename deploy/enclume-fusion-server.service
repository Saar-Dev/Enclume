[Unit]
Description=Enclume Shared Integration API Server
After=network.target docker.service

[Service]
Type=simple
User=codex
WorkingDirectory=/home/codex/Enclume-fusion/server
ExecStart=/usr/bin/node --env-file=../.env --es-module-specifier-resolution=node src/index.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
