{
  "name": "enclume-integrated",
  "private": true,
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "scripts": {
    "test:world": "node --test shared/world/*.test.mjs server/src/services/*.test.mjs",
    "test:server-config": "node --test server/src/lib/clientOrigins.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:remote": "bash tests/e2e/run-remote.sh",
    "test:e2e:remote:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File tests/e2e/run-remote.ps1"
  },
  "dependencies": {
    "csv-parse": "^7.0.1",
    "csv-parser": "^3.2.0",
    "fast-voxel-raycast": "^0.1.1",
    "image-size": "^2.0.2",
    "jszip": "^3.10.1",
    "polygon-clipping": "^0.15.7",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
